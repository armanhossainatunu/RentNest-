model Property {
  id          String         @id @default(uuid())
  title       String
  thumbnail   String?
  description String
  price       Float
  status      PropertyStatus
  authorId    String
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  location    String
  bedrooms    Int?
  bathrooms   Int?
  views       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  reviews     Review[]

  @@index([authorId])
  @@map("properties")
}
