model Property {
    id          String   @id @default(uuid())
    title       String
    thumbnail   String?
    description String?
    price       Float?
    address     String?
    city        String?
    state       String?
    zipCode     String?
    bedrooms    Int?
    bathrooms   Int?
    ownerId     String
    owner       User     @relation(fields: [ownerId], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("properties")
}
